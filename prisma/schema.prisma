datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum UserRole {
  customer
  admin
}

enum DiscountType {
  fixed
  percentage
}

enum OrderStatus {
  pending
  paid
  shipped
  delivered
  cancelled
}

model Profile {
  id        String   @id @db.Uuid // Matches Supabase Auth User ID
  email     String   @unique
  fullName  String?
  avatarUrl String?
  role      UserRole @default(customer)
  createdAt DateTime @default(now()) @map("created_at")
  orders    Order[]

  @@map("profiles")
}

model Category {
  id          String    @id @default(uuid()) @db.Uuid
  name        String
  slug        String    @unique
  description String?
  imageUrl    String?   @map("image_url")
  createdAt   DateTime  @default(now()) @map("created_at")
  products    Product[]

  @@map("categories")
}

model Product {
  id          String      @id @default(uuid()) @db.Uuid
  name        String
  slug        String      @unique
  description String?
  price          Decimal     @db.Decimal(10, 2)
  compareAtPrice Decimal?    @db.Decimal(10, 2) @map("compare_at_price")
  wholesalePrice Decimal?    @db.Decimal(10, 2) @map("wholesale_price")
  moq            Int?        @default(1)
  images         String[]    @default([])
  sizeChart      String?     @map("size_chart")      // URL of the size chart image
  searchKeywords String?     @map("search_keywords") // Comma-separated search keywords
  colors         Json?       @default("[]")          // [{ name: "Red", hex: "#FF0000" }]
  sizes          String[]    @default([])            // ["XS","S","M","L","XL","XXL"]
  stock       Int         @default(0)
  isFeatured  Boolean     @default(false) @map("is_featured")
  categoryId  String?     @db.Uuid @map("category_id")
  category    Category?   @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  features         String?     @db.Text
  careInstructions String?     @db.Text @map("care_instructions")
  createdAt        DateTime    @default(now()) @map("created_at")
  orderItems  OrderItem[]

  @@index([categoryId])
  @@map("products")
}

model Order {
  id                String      @id @default(uuid()) @db.Uuid
  userId            String      @db.Uuid @map("user_id")
  user              Profile     @relation(fields: [userId], references: [id], onDelete: Cascade)
  status            OrderStatus @default(pending)
  totalPrice        Decimal     @db.Decimal(10, 2) @map("total_price")
  shippingAddress   Json        @map("shipping_address")
  razorpayOrderId   String?     @map("razorpay_order_id")
  razorpayPaymentId String?     @map("razorpay_payment_id")
  createdAt         DateTime    @default(now()) @map("created_at")
  orderItems        OrderItem[]
  couponId          String?     @db.Uuid @map("coupon_id")
  coupon            Coupon?     @relation(fields: [couponId], references: [id], onDelete: SetNull)
  discountApplied   Decimal?    @db.Decimal(10, 2) @default(0) @map("discount_applied")

  @@index([userId])
  @@index([couponId])
  @@map("orders")
}

model OrderItem {
  id        String  @id @default(uuid()) @db.Uuid
  orderId   String  @db.Uuid @map("order_id")
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String  @db.Uuid @map("product_id")
  product   Product @relation(fields: [productId], references: [id], onDelete: Restrict)
  quantity  Int
  price     Decimal @db.Decimal(10, 2) // Saved historical price at checkout time
  variantColor Json?   @map("variant_color") // { name: string, hex: string }
  variantSize  String? @map("variant_size")

  @@index([orderId])
  @@index([productId])
  @@map("order_items")
}

model Coupon {
  id             String       @id @default(uuid()) @db.Uuid
  code           String       @unique
  discountType   DiscountType @map("discount_type")
  discountValue  Decimal      @db.Decimal(10, 2) @map("discount_value")
  isForRetail    Boolean      @default(true) @map("is_for_retail")
  isForWholesale Boolean      @default(false) @map("is_for_wholesale")
  isActive       Boolean      @default(true) @map("is_active")
  createdAt      DateTime     @default(now()) @map("created_at")
  orders         Order[]

  @@map("coupons")
}
